# Supabase project credentials (found in Project Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Google Gemini API key (for embeddings + RAG answers)
# Get one at https://aistudio.google.com/app/apikey
# Leave blank to run in fallback (string-match only) mode
GEMINI_API_KEY=

# Port the FastAPI server listens on (optional, defaults to 8000)
PORT=8000
